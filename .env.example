# Browser-safe Supabase settings for the Vite admin interface. The publishable key is public and is NOT a service-role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only variables (do not expose any of these to Vite/browser code).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
VERSEL_RESEND_API_KEY=
FORM_NOTIFICATION_TO=studio@postervalley.nl
FORM_NOTIFICATION_FROM="Poster Valley <studio@auth.hetprojectmakersbureau.nl>"
FORM_NOTIFICATION_REPLY_TO=studio@postervalley.nl
SITE_URL=https://www.postervalley.nl
ADMIN_ACTION_SECRET=
# A3.2 operational invitation delivery. Keep these server-only. Preview,
# Staging, development and tests remain suppressed regardless of API keys.
POSTER_VALLEY_ENV=development
OPERATIONAL_EMAIL_DELIVERY_ENABLED=false
OPERATIONAL_EMAIL_FROM="Poster Valley <studio@mail.postervalley.nl>"
OPERATIONAL_EMAIL_REPLY_TO=studio@postervalley.nl
ADMIN_INVITATION_TOKEN_SECRET=
ADMIN_CONFIRMATION_SECRET=
MOLLIE_API_KEY=
MOLLIE_TEST_MODE=
